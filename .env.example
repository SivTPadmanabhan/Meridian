# .env.example — copy to .env and fill in secret values. .env is gitignored.

# LLM providers
ANTHROPIC_API_KEY=
ANTHROPIC_TRIAGE_MODEL=claude-haiku-4-5
ANTHROPIC_ANALYSIS_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-5.4-mini

# Agent behavior
TRIAGE_CONFIDENCE_ESCALATION=0.6

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Database
DATABASE_URL=postgresql+asyncpg://meridian:password@localhost:5432/meridian

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=600

# Langfuse (self-hosted v3 via docker compose)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=
SLACK_INGEST_CHANNEL_ID=
SLACK_INGEST_LIMIT=100

# GitHub / GitLab
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# Notion runbook sync (V2)
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28

# Salesforce (V2 — RevOps webhook + OAuth refresh)
SALESFORCE_WEBHOOK_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=
SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# Application
APP_ENV=development
LOG_LEVEL=INFO
